<view class="page">
  <!-- 顶部安全区 -->
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- 红色光晕装饰 -->
  <view class="glow-orb"></view>

  <!-- 顶部品牌区 -->
  <view class="brand">
    <view class="brand-row">
      <view class="brand-logo">🔍</view>
      <text class="brand-name">人话翻译机</text>
    </view>
    <text class="brand-slogan">粘贴话术，一键看穿真相</text>
  </view>

  <!-- 场景选择栏 -->
  <scroll-view class="scene-scroll" scroll-x enable-flex>
    <view class="scene-list">
      <view
        wx:for="{{scenes}}"
        wx:key="id"
        class="scene-pill {{currentScene === item.id ? (item.id === 'reverse' ? 'scene-pill--active-green' : 'scene-pill--active') : ''}}"
        bind:tap="onSceneChange"
        data-id="{{item.id}}"
      >
        {{item.icon}} {{item.label}}
      </view>
    </view>
  </scroll-view>

  <!-- 文本输入区 -->
  <view class="input-card {{inputFocused ? 'input-card--focus' : ''}}">
    <textarea
      class="input-area"
      value="{{inputText}}"
      placeholder="{{currentPlaceholder}}"
      placeholder-class="input-placeholder"
      maxlength="500"
      auto-height
      bindinput="onInput"
      bindfocus="onFocus"
      bindblur="onBlur"
    />
    <view class="input-divider"></view>
    <view class="input-toolbar">
      <text class="char-count">{{inputText.length}}/500</text>
      <view class="toolbar-btns">
        <view class="paste-btn" bind:tap="onPaste">📋 粘贴</view>
        <view
          class="translate-btn {{!inputText || isLoading ? 'translate-btn--disabled' : ''}}"
          bind:tap="onTranslate"
        >
          {{currentScene === 'reverse' ? '✨ 上妆' : '🔍 翻译人话'}}
        </view>
      </view>
    </view>
  </view>

  <!-- 加载态 -->
  <view class="loading-box" wx:if="{{isLoading}}">
    <text class="loading-main">{{currentScene === 'reverse' ? '✨ 正在疯狂上妆…' : '🔍 正在粉碎话术…'}}</text>
    <text class="loading-sub">AI 正在扒开 {{loadingLayers}} 层包装</text>
  </view>

  <!-- 翻译结果区 -->
  <view class="result-area {{showResult ? 'result-area--show' : ''}}" wx:if="{{result}}">

    <!-- 妆感浓度仪表 -->
    <view class="meter-card">
      <view class="meter-content">
        <view class="meter-left">
          <text class="meter-label">💄 {{currentScene === 'reverse' ? '上妆浓度' : '妆感浓度'}}</text>
          <view class="meter-track">
            <view class="meter-fill" style="width: {{animatedScore}}%;"></view>
          </view>
          <view class="meter-scale">
            <text>素颜</text>
            <text>淡妆</text>
            <text>浓妆</text>
            <text>整容</text>
          </view>
        </view>
        <view class="meter-right">
          <view class="meter-score-row">
            <text class="meter-score">{{result.score}}</text>
            <text class="meter-percent">%</text>
          </view>
          <text class="meter-verdict">{{result.verdict}}</text>
        </view>
      </view>
    </view>

    <!-- 翻译结果卡片 -->
    <view class="result-card">
      <!-- 原文 -->
      <view class="result-section">
        <view class="section-label">
          <view class="dot dot--red"></view>
          <text class="label-text label-text--red">{{currentScene === 'reverse' ? '原文 · 大白话' : '原文 · 话术版'}}</text>
        </view>
        <text class="original-text">{{inputText}}</text>
      </view>

      <!-- 人话翻译 -->
      <view class="result-section result-section--green">
        <view class="section-label">
          <view class="dot dot--green"></view>
          <text class="label-text label-text--green">{{currentScene === 'reverse' ? '上妆 · 高大上版' : '人话 · 真实含义'}}</text>
        </view>
        <text class="human-text">{{result.humanText}}</text>
      </view>

      <!-- 逐句拆解 -->
      <view class="result-section">
        <view class="section-label">
          <text class="label-text label-text--gray">🔬 逐句拆解</text>
        </view>
        <view class="breakdown-list">
          <view
            class="breakdown-item"
            wx:for="{{result.breakdown}}"
            wx:key="index"
          >
            <text class="breakdown-from">{{item.from}}</text>
            <text class="breakdown-arrow">→</text>
            <text class="breakdown-to">{{item.to}}</text>
          </view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="action-bar">
        <view class="action-btn action-btn--gray" bind:tap="onShare">
          📤 分享
        </view>
        <view class="action-btn action-btn--gray" bind:tap="onCopy">
          📋 复制
        </view>
        <view class="action-btn action-btn--primary" bind:tap="onRetranslate">
          再译一条
        </view>
      </view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view style="height: 60rpx;"></view>
</view>
