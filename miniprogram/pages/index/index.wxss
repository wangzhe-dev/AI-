.page {
  min-height: 100vh;
  background-color: #0a0a0f;
  position: relative;
  overflow: hidden;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 光晕装饰 ========== */
.glow-orb {
  position: absolute;
  top: -80rpx;
  left: -80rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 77, 77, 0.25) 0%, transparent 70%);
  pointer-events: none;
}

/* ========== 品牌区 ========== */
.brand {
  padding: 32rpx 40rpx 0;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.brand-logo {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #ff4d4d, #ff9100);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  line-height: 72rpx;
  text-align: center;
}

.brand-name {
  font-size: 40rpx;
  font-weight: 900;
  background: linear-gradient(90deg, #ff4d4d, #ff9100);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.brand-slogan {
  display: block;
  font-size: 24rpx;
  color: #6a6a80;
  margin-top: 8rpx;
  padding-left: 88rpx;
}

/* ========== 场景选择栏 ========== */
.scene-scroll {
  margin-top: 36rpx;
  padding: 0 40rpx;
  white-space: nowrap;
}

.scene-list {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 40rpx;
}

.scene-pill {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  background: #13131a;
  border: 1rpx solid #2a2a3a;
  font-size: 26rpx;
  color: #6a6a80;
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.3s;
}

.scene-pill--active {
  background: rgba(255, 77, 77, 0.12);
  border-color: #ff4d4d;
  color: #ff4d4d;
  font-weight: 600;
}

.scene-pill--active-green {
  background: rgba(0, 230, 118, 0.10);
  border-color: #00e676;
  color: #00e676;
  font-weight: 600;
}

/* ========== 文本输入区 ========== */
.input-card {
  margin: 28rpx 40rpx 0;
  background: #13131a;
  border: 1rpx solid #2a2a3a;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  transition: border-color 0.3s, box-shadow 0.3s;
}

.input-card--focus {
  border-color: #ff4d4d;
  box-shadow: 0 0 6rpx rgba(255, 77, 77, 0.3);
}

.input-area {
  width: 100%;
  min-height: 160rpx;
  font-size: 30rpx;
  line-height: 1.7;
  color: #e8e8f0;
  background: transparent;
}

.input-placeholder {
  color: #4a4a5e;
  font-size: 28rpx;
}

.input-divider {
  height: 1rpx;
  background: #2a2a3a;
  margin: 20rpx 0;
}

.input-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.char-count {
  font-size: 22rpx;
  color: #4a4a5e;
}

.toolbar-btns {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.paste-btn {
  font-size: 24rpx;
  color: #6a6a80;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  background: #1a1a24;
  border: 1rpx solid #2a2a3a;
}

.translate-btn {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  padding: 14rpx 32rpx;
  border-radius: 40rpx;
  background: linear-gradient(90deg, #ff4d4d, #ff9100);
  box-shadow: 0 4rpx 16rpx rgba(255, 77, 77, 0.3);
  transition: opacity 0.3s;
}

.translate-btn--disabled {
  opacity: 0.4;
  pointer-events: none;
}

/* ========== 加载态 ========== */
.loading-box {
  text-align: center;
  padding: 48rpx 40rpx 0;
}

.loading-main {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #ff4d4d;
  animation: breathe 1.4s ease-in-out infinite;
}

.loading-sub {
  display: block;
  font-size: 24rpx;
  color: #6a6a80;
  margin-top: 12rpx;
}

@keyframes breathe {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* ========== 翻译结果区 ========== */
.result-area {
  margin-top: 36rpx;
  padding: 0 40rpx;
  opacity: 0;
  transform: translateY(18rpx);
  transition: all 0.45s ease-out;
}

.result-area--show {
  opacity: 1;
  transform: translateY(0);
}

/* --- 妆感浓度仪表 --- */
.meter-card {
  background: #13131a;
  border: 1rpx solid #2a2a3a;
  border-radius: 28rpx;
  padding: 32rpx 36rpx;
}

.meter-content {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.meter-left {
  flex: 1;
  overflow: hidden;
}

.meter-label {
  font-size: 22rpx;
  color: #6a6a80;
}

.meter-track {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 6rpx;
  margin-top: 16rpx;
  overflow: hidden;
}

.meter-fill {
  height: 100%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #ff4d4d, #ff9100);
  box-shadow: 0 0 12rpx rgba(255, 77, 77, 0.5);
  transition: width 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.meter-scale {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}

.meter-scale text {
  font-size: 18rpx;
  color: #4a4a5e;
}

.meter-right {
  text-align: center;
  flex-shrink: 0;
}

.meter-score-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.meter-score {
  font-size: 72rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #ff4d4d, #ff9100);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
}

.meter-percent {
  font-size: 28rpx;
  color: #6a6a80;
  margin-left: 4rpx;
}

.meter-verdict {
  font-size: 22rpx;
  color: #ff4d4d;
  font-weight: 600;
  margin-top: 8rpx;
}

/* --- 翻译结果卡片 --- */
.result-card {
  background: #13131a;
  border: 1rpx solid #2a2a3a;
  border-radius: 28rpx;
  margin-top: 24rpx;
  overflow: hidden;
}

.result-section {
  padding: 32rpx 36rpx;
  border-top: 1rpx solid #2a2a3a;
}

.result-section:first-child {
  border-top: none;
}

.result-section--green {
  background: rgba(0, 230, 118, 0.03);
}

.section-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.dot--red {
  background: #ff4d4d;
}

.dot--green {
  background: #00e676;
}

.label-text {
  font-size: 20rpx;
}

.label-text--red {
  color: #ff4d4d;
}

.label-text--green {
  color: #00e676;
}

.label-text--gray {
  color: #6a6a80;
}

.original-text {
  font-size: 26rpx;
  color: #6a6a80;
  line-height: 1.8;
  text-decoration: line-through;
  text-decoration-color: rgba(255, 77, 77, 0.25);
}

.human-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #e8e8f0;
  line-height: 1.8;
}

/* --- 逐句拆解 --- */
.breakdown-list {
  margin-top: 8rpx;
}

.breakdown-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.03);
  gap: 12rpx;
}

.breakdown-item:last-child {
  border-bottom: none;
}

.breakdown-from {
  font-size: 26rpx;
  color: #6a6a80;
  text-decoration: line-through;
  text-decoration-color: rgba(255, 77, 77, 0.25);
  flex-shrink: 0;
  max-width: 40%;
}

.breakdown-arrow {
  font-size: 24rpx;
  color: #4a4a5e;
  flex-shrink: 0;
  line-height: 1.8;
}

.breakdown-to {
  font-size: 26rpx;
  color: #00e676;
  font-weight: 600;
  flex: 1;
}

/* --- 操作按钮 --- */
.action-bar {
  display: flex;
  gap: 20rpx;
  padding: 28rpx 36rpx;
  border-top: 1rpx solid #2a2a3a;
}

.action-btn {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  padding: 22rpx 0;
  border-radius: 20rpx;
  transition: opacity 0.2s;
}

.action-btn:active {
  opacity: 0.7;
}

.action-btn--gray {
  background: #1a1a24;
  border: 1rpx solid #2a2a3a;
  color: #6a6a80;
}

.action-btn--primary {
  background: linear-gradient(90deg, #ff4d4d, #ff9100);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(255, 77, 77, 0.3);
}
